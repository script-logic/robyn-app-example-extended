{
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
        }
    },
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
    "python.autoComplete.extraPaths": [
        "${workspaceFolder}/src"
    ],
    "python.analysis.autoImportCompletions": true,
    "python.analysis.completeFunctionParens": true,
    "python.analysis.extraPaths": ["${workspaceFolder}"],
    "python.analysis.typeCheckingMode": "basic",
    "python.languageServer": "Pylance",
    "python.testing.pytestArgs": [
        "${workspaceFolder}"
    ],
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true,

    "ty.completions.autoImport": true,
    "ty.diagnosticMode": "workspace",
    "ty.disableLanguageServices": false,
    "ty.importStrategy": "useBundled",
    "ty.path": [
        "${workspaceFolder}/.venv/Scripts/ty.exe"
    ],

    "ruff.path": ["${workspaceFolder}/.venv/Scripts/ruff.exe"],
    "ruff.interpreter": ["${workspaceFolder}/.venv/Scripts/python.exe"],
    "ruff.importStrategy": "fromEnvironment",
}
